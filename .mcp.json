{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "REMPLACE_PAR_TON_TOKEN"
      }
    },
    "make": {
      "type": "sse",
      "url": "https://mcp.make.com/mcp/sse",
      "headers": {
        "Authorization": "Bearer REMPLACE_PAR_TON_TOKEN_MAKE"
      }
    }
  }
}
